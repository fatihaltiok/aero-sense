# Kopiere diese Datei nach .env.local (Frontend) bzw. .env (Backend)

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# URL des Backends — lokal: http://localhost:8000, Produktion: https://deine-domain.render.com
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Backend (FastAPI) ─────────────────────────────────────────────────────────
# Komma-getrennte Liste erlaubter CORS-Origins
CORS_ORIGINS=http://localhost:3000

# ML-Modell: Kontaminationsrate für Isolation Forest (0.01–0.2)
ML_CONTAMINATION=0.05
